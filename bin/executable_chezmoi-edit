#!/usr/bin/env nu

def main [
	...files: path
	--editor (-e) = nano
] {
	for $f in $files {
		with-env {
			EDITOR: (which $editor).path.0
		} {
			chezmoi edit $f
		}
	}
	cd ~/.local/share/chezmoi
	git add .
	try { git commit -m - }
	git push
	chezmoi update
	open ~/Machines.txt | sshp -j 'chezmoi update'
}
