#!/usr/bin/env nu

def main [
	...files: path
	--editor (-e) = nano
] {
	$files | each {|f| (with-env
		{ EDITOR: (which $editor).0.path }
		{ chezmoi edit $f }
	) }
	cd ~/.local/share/chezmoi
	git add .
	try { git commit -m - }
	git pull
	git push
	chezmoi update
	open ~/Machines.txt | sshp -j 'chezmoi update'
}
