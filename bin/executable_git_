#!/usr/bin/env bash
set -uo pipefail
[[ -d .git ]] || git init
[[ -f .gitignore ]] || echo ".flags/local" > .gitignore
[[ -f .editorconfig ]] || cat << 'EOF'> .editorconfig
root = true
[*]
	indent_style = tab
	indent_size = 4
	trim_trailing_whitespace = true
	insert_final_newline = true
	charset = utf-8
[*.{y,ya}ml]
	indent_style = space
	indent_size = 2
EOF
if ! [[ -f main.sh ]]; then
	new bash main.sh
	chmod +x main.sh
fi
if ! [[ -d .flags ]]; then
	mkdir -p .flags/local
	echo . > .flags/.gitkeep
	echo . > .flags/local/.keep
fi
