#!/usr/bin/env bash
set -uo pipefail
[[ -d .git ]] || git init
[[ -f .gitignore ]] || echo ".flags/local" > .gitignore
[[ -f .editorconfig ]] || cat << '!'> .editorconfig
root = true
[*]
	indent_style = tab
	indent_size = 4
	trim_trailing_whitespace = true
	insert_final_newline = true
	charset = utf-8
[*.{y,ya}ml]
	indent_style = space
	indent_size = 2
!
if ! [[ -f main.sh ]]; then
	new bash main.sh
	chmod +x main.sh
fi
