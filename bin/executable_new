#!/usr/bin/env bash
err() {
	printf '[\e[91mERR\e[0m]: %s\n' "$*" >&2
	exit 1
}
cmd=${BASH_SOURCE##*/}
case "$#" in
	0) err "'$cmd' must take a language argument";;
	1) err "'$cmd' must take a name argument";;
esac
lang=${1,,}
shift
type=
# shellcheck disable=2016
case "$lang" in
	bash)
		type=file
		lines=(
			'#!/usr/bin/env bash'
			'set -uo pipefail'
			'if command -v shellcheck &> /dev/null; then'
			$'\tshellcheck "$0" || exit'
			'fi'
		)
	;;
	nu|nushell)
		type=file
		lines=(
			'#!/usr/bin/env nu'
			''
			'def main [] {}'
		)
	;;
	project) type=project;;
	*) err "'$lang' is an invalid language";;
esac
name=$1
shift
case "$type" in
	file)
		printf '%s\n' "${lines[@]}" >> "$name"
		chmod +x "$name"
	;;
	project) ~/bin/.new/project "$name";;
esac
